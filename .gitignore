# Local Framer video exports for preview reference; heavy runtime video must use
# reviewed public assets or CDN-hosted files instead of new Git blobs.
Framer/*.mp4
Framer/*.zip
# Future Framer PNG source exports are ignored by default. Reviewed runtime
# PNGs that are already tracked remain available until a dedicated asset
# optimization pass moves them to an approved runtime path.
Framer/*.png

# local heavy 3D source drops and generated review assets
3D Plat/
3D photo/
3D Plat/RavioliAvecAssiete.glb
3D Plat/HomardAvecAssiette.glb
3D Plat/Homard bleu Meshy.glb
3D Plat/SouffleAvecAssiette.glb
assets/3d/source/**
!assets/3d/source/**/
!assets/3d/source/**/.gitkeep
assets/3d/work/**
!assets/3d/work/**/
!assets/3d/work/**/.gitkeep
assets/3d/reports/**
!assets/3d/reports/**/
!assets/3d/reports/**/.gitkeep

